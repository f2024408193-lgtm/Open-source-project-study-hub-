import unittest
import sqlite3
import os
import db


class TestStudyHubDatabase(unittest.TestCase):

    def setUp(self):
        if os.path.exists(db.DB_PATH):
            os.remove(db.DB_PATH)

        db.init_db()

    def tearDown(self):
        if os.path.exists(db.DB_PATH):
            os.remove(db.DB_PATH)

    def test_user_authentication_flow(self):

        username = "qa_tester"
        password = "SecurePassword123!"

        ok, _ = db.register_user(username, password)
        self.assertTrue(ok)

        ok, _ = db.register_user(username, "anotherPassword")
        self.assertFalse(ok)

        user_id = db.login_user(username, password)
        self.assertIsNotNone(user_id)

        wrong_login = db.login_user(username, "WrongPassword")
        self.assertIsNone(wrong_login)

    def test_task_management_crud(self):

        ok, _ = db.register_user("task_user", "pass")
        self.assertTrue(ok)

        user_id = db.login_user("task_user", "pass")

        db.add_task(
            user_id,
            "Complete OSSD Project",
            "2026-06-25"
        )

        tasks = db.get_tasks(user_id)

        self.assertEqual(len(tasks), 1)
        self.assertEqual(
            tasks[0]["title"],
            "Complete OSSD Project"
        )

        task_id = tasks[0]["id"]

        db.toggle_task(task_id)

        tasks = db.get_tasks(user_id)

        self.assertEqual(tasks[0]["done"], 1)

        db.delete_task(task_id)

        tasks = db.get_tasks(user_id)

        self.assertEqual(len(tasks), 0)

    def test_sql_injection_resilience(self):

        malicious_username = "admin' OR '1'='1"

        ok, _ = db.register_user(
            malicious_username,
            "password"
        )

        self.assertTrue(ok)

        login = db.login_user(
            "nonexistent",
            malicious_username
        )

        self.assertIsNone(login)

    def test_stats(self):

        ok, _ = db.register_user("stats_user", "pass")
        self.assertTrue(ok)

        user_id = db.login_user(
            "stats_user",
            "pass"
        )

        db.add_task(user_id, "Task 1", "2026-01-01")
        db.add_task(user_id, "Task 2", "2026-01-02")

        tasks = db.get_tasks(user_id)

        db.toggle_task(tasks[0]["id"])

        db.add_note(
            user_id,
            "Note 1",
            "Test note"
        )

        stats = db.get_stats(user_id)

        self.assertEqual(stats["tasks_total"], 2)
        self.assertEqual(stats["tasks_done"], 1)
        self.assertEqual(stats["tasks_pending"], 1)
        self.assertEqual(stats["notes_total"], 1)


if __name__ == "__main__":
    unittest.main(verbosity=2)
